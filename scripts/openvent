#!/usr/bin/env bash
#
# openvent — helper for backing up, restoring, and installing OpenVent firmware
#            on a Bigtreetech Panda Vent (or any classic ESP32).
#
# Usage:
#   openvent backup  [-p PORT] [-o FILE]
#   openvent restore [-p PORT] FILE
#   openvent install [-p PORT] [-t TAG] [-f FILE]
#   openvent help
#
# Examples:
#   openvent backup                                       # → stock-panda-vent-backup-<ts>.bin
#   openvent backup -o my-backup.bin
#   openvent install                                      # latest release
#   openvent install -t v0.2.0                            # specific tag
#   openvent install -f build/openvent-full.bin           # local file
#   openvent restore my-backup.bin
#
# Requires `esptool` (install with `pip install esptool`). GitHub download uses
# `curl` if the `gh` CLI isn't installed.

set -euo pipefail

REPO="${OPENVENT_REPO:-justinh-rahb/openvent}"
CHIP="esp32"
BAUD="460800"
FLASH_SIZE_BYTES=4194304   # 4 MB — matches the Panda Vent module

die() { echo "openvent: $*" >&2; exit 1; }

require_esptool() {
    if command -v esptool >/dev/null 2>&1; then ESPTOOL=(esptool)
    elif command -v esptool.py >/dev/null 2>&1; then ESPTOOL=(esptool.py)
    elif command -v python3 >/dev/null 2>&1 && python3 -c "import esptool" 2>/dev/null; then
        ESPTOOL=(python3 -m esptool)
    else
        die "esptool not found. Install with: python3 -m pip install esptool"
    fi
}

# Best-effort port autodetect: pick the first tty.usbserial* / ttyUSB* / ttyACM*.
autodetect_port() {
    local p
    for p in /dev/tty.usbserial-* /dev/ttyUSB* /dev/ttyACM*; do
        [ -e "$p" ] && { echo "$p"; return 0; }
    done
    return 1
}

# ---------- subcommands ----------

cmd_backup() {
    local port="" output=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -p) port="$2"; shift 2 ;;
            -o) output="$2"; shift 2 ;;
            *)  die "unknown arg: $1" ;;
        esac
    done
    [ -n "$port" ] || port="$(autodetect_port || die "no serial port found — pass -p /dev/tty.usbserial-XXXX")"
    [ -n "$output" ] || output="stock-panda-vent-backup-$(date +%Y%m%d-%H%M%S).bin"

    echo "→ dumping ${FLASH_SIZE_BYTES} bytes from $port to $output"
    "${ESPTOOL[@]}" --chip "$CHIP" -p "$port" -b "$BAUD" \
        read_flash 0x0 "$FLASH_SIZE_BYTES" "$output"
    echo "✓ backup saved: $output"
    echo "  keep this file safe — it's your only way back to stock firmware."
}

cmd_restore() {
    local port="" file=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -p) port="$2"; shift 2 ;;
            -*) die "unknown arg: $1" ;;
            *)  file="$1"; shift ;;
        esac
    done
    [ -n "$file" ] || die "usage: openvent restore [-p PORT] FILE"
    [ -f "$file" ] || die "not a file: $file"
    [ -n "$port" ] || port="$(autodetect_port || die "no serial port found — pass -p /dev/tty.usbserial-XXXX")"

    echo "→ restoring $file to $port"
    "${ESPTOOL[@]}" --chip "$CHIP" -p "$port" -b "$BAUD" \
        write_flash 0x0 "$file"
    echo "✓ restore complete"
}

# Download a release asset. Prefers `gh` if available for auth/rate-limit
# reasons; falls back to curl for anonymous fetch.
download_release() {
    local tag="$1" out="$2"
    if command -v gh >/dev/null 2>&1; then
        gh release download "$tag" --repo "$REPO" \
            --pattern 'openvent-full.bin' --output "$out" --clobber
    else
        local url="https://github.com/$REPO/releases/download/$tag/openvent-full.bin"
        [ "$tag" = "latest" ] && url="https://github.com/$REPO/releases/latest/download/openvent-full.bin"
        echo "→ fetching $url"
        curl -fSL "$url" -o "$out" || die "download failed — check the tag or network"
    fi
}

cmd_install() {
    local port="" tag="" file=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -p) port="$2"; shift 2 ;;
            -t) tag="$2"; shift 2 ;;
            -f) file="$2"; shift 2 ;;
            *)  die "unknown arg: $1" ;;
        esac
    done
    [ -n "$port" ] || port="$(autodetect_port || die "no serial port found — pass -p /dev/tty.usbserial-XXXX")"

    local image
    if [ -n "$file" ]; then
        [ -f "$file" ] || die "not a file: $file"
        image="$file"
        echo "→ installing local file $image on $port"
    else
        [ -n "$tag" ] || tag="latest"
        image="$(mktemp -t openvent-full.XXXXXX.bin)"
        trap 'rm -f "$image"' EXIT
        download_release "$tag" "$image"
        echo "→ installing release $tag on $port"
    fi

    "${ESPTOOL[@]}" --chip "$CHIP" -p "$port" -b "$BAUD" \
        write_flash 0x0 "$image"
    echo "✓ install complete — the device will reboot into OpenVent."
    echo "  first-time users: join the 'OpenVent_XXXX' hotspot (password 987654321)"
    echo "  and configure WiFi + Moonraker through the captive portal."
}

cmd_help() {
    sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
}

# ---------- dispatch ----------

sub="${1:-help}"
shift || true

case "$sub" in
    backup)  require_esptool; cmd_backup  "$@" ;;
    restore) require_esptool; cmd_restore "$@" ;;
    install) require_esptool; cmd_install "$@" ;;
    help|-h|--help) cmd_help ;;
    *) die "unknown subcommand: $sub (try 'openvent help')" ;;
esac
